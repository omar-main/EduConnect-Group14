<?xml version="1.0" encoding="utf-8"?>
<configuration>

  <appSettings>
    <add key="ValidationSettings:UnobtrusiveValidationMode" value="None" />
  </appSettings>

  <connectionStrings>
    <!--
      EduConnectDB — used by all code-behind files via ConfigurationManager.
      AttachDbFilename points to App_Data\EduConnect.mdf (SQL Server LocalDB).
      Change Data Source to .\SQLEXPRESS if you are using SQL Server Express instead.
    -->
    <add name="EduConnectDB"
         connectionString="Data Source=(LocalDB)\MSSQLLocalDB;Initial Catalog=EduConnect;Integrated Security=True"
         providerName="System.Data.SqlClient" />
  </connectionStrings>

  <system.web>
    <compilation debug="true" targetFramework="4.8" />
    <httpRuntime targetFramework="4.8" requestValidationMode="2.0" />
    <!-- Session timeout in minutes -->
    <sessionState timeout="30" />
  </system.web>

</configuration>
